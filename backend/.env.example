NODE_ENV=production
PORT=3000
FRONTEND_URL=https://xyndrome.lk
FRONTEND_URLS=https://xyndrome.lk,https://www.xyndrome.lk
APP_PUBLIC_URL=https://xyndrome.lk/lms
API_PUBLIC_URL=https://xyndrome.lk/api
BODY_LIMIT=8mb
ALLOW_LAN_ORIGINS=false
SETTINGS_ENCRYPTION_KEY=replace-with-at-least-32-random-characters
HEALTH_METRICS_TOKEN=replace-with-a-long-random-health-token
EXPOSE_DEV_RESET_TOKEN=false
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_IDS=
GOOGLE_CLIENT_SECRET=
VAPID_SUBJECT=mailto:admin@example.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=com.erpm.medical.lms
APNS_USE_SANDBOX=true
APNS_PRIVATE_KEY_PATH=
APNS_PRIVATE_KEY=
FCM_PROJECT_ID=
FCM_SERVER_KEY=
FCM_SERVICE_ACCOUNT_PATH=
FCM_SERVICE_ACCOUNT_JSON=
SMART_NOTES_LAYOUT_API_KEY=
SMART_NOTES_LAYOUT_MODEL=gemini-2.5-flash
SMART_NOTES_IMAGE_API_KEY=
SMART_NOTES_IMAGE_MODEL=gemini-2.5-flash-image
DB_HOST=localhost
DB_PORT=3306
DB_USER=lms_app
DB_PASSWORD=replace-with-a-strong-database-password
DB_NAME=lms_db
DB_CONNECTION_LIMIT=8
DB_MAX_IDLE=4
DB_IDLE_TIMEOUT=60000
DB_CONNECT_TIMEOUT=10000
DB_QUEUE_LIMIT=100
