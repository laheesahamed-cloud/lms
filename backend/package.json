{
  "name": "lms-backend",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "npm run build && npm run test:unit && npm run test:e2e",
    "test:unit": "cd .. && node scripts/qa/sql-injection-regression.mjs && node scripts/qa/auth-regression.mjs && node scripts/qa/access-control-regression.mjs && node scripts/qa/secrets-regression.mjs && node scripts/qa/owasp-regression.mjs",
    "test:e2e": "ts-node --project tsconfig.test.json test/security.e2e.ts",
    "test:security": "npm run test:unit && npm run test:e2e",
    "test:smoke": "npm run build",
    "migrate": "node scripts/migrate.mjs",
    "push:vapid": "node scripts/generate-vapid-keys.mjs",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch"
  },
  "dependencies": {
    "@google/genai": "^1.50.1",
    "@google/generative-ai": "^0.24.1",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.0",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/platform-express": "^11.0.0",
    "@types/nodemailer": "^8.0.0",
    "@types/web-push": "^3.6.4",
    "bcryptjs": "^3.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "mysql2": "^3.14.0",
    "nodemailer": "^8.0.7",
    "openai": "^6.34.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/node": "^22.14.1",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.4.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.4"
  }
}
