<IfModule mod_rewrite.c>
  RewriteEngine On

  RewriteCond %{HTTP_HOST} ^www\.xyndrome\.lk$ [NC]
  RewriteRule ^ https://xyndrome.lk%{REQUEST_URI} [R=301,L]

  RewriteBase /lms/frontend/dist/
  RewriteRule ^index\.html$ - [L]

  RewriteCond %{REQUEST_URI} \.(?:js|mjs|css|map|json|webmanifest|txt|xml|png|jpe?g|gif|webp|svg|ico|woff2?|ttf)$ [NC]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteRule ^ - [R=404,L]

  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /lms/frontend/dist/index.html [L]
</IfModule>

<IfModule mod_mime.c>
  AddType application/javascript .js .mjs
  AddType text/css .css
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/avif "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType text/javascript "access plus 1 month"
</IfModule>

<IfModule mod_headers.c>
  # App-HTML security headers (report sec 13.1-13.2). The inline script
  # hashes are filled in by scripts/build/sync-root-index.mjs at build time —
  # never hand-edit the sha256 values. script-src carries NO 'unsafe-inline'.
  # style-src deviation from sec 13.1: eight components (incl. the website
  # hero) render dynamic <style> elements, which CSP cannot hash, and a hash
  # next to 'unsafe-inline' would disable the latter — so styles allow
  # inline until those components move their CSS into files.
  # Production notes:
  #  - add HSTS at the HTTPS host (Header always set Strict-Transport-Security)
  #  - if Google Sign-In is enabled, add https://accounts.google.com to
  #    script-src and frame-src
  #  - for LAN device testing through Apache, add http://<lan-ip>:3000 to
  #    connect-src (or temporarily relax it)
  <FilesMatch "^index\.html$">
    Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'sha256-nxMHs8nI6qx30auEmBQwu9Jf5r+x5TlPLIby8Tbw8yg='; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https://api.dicebear.com; connect-src 'self' http://localhost:3000 http://127.0.0.1:3000; worker-src 'self'; manifest-src 'self'; object-src 'none'; base-uri 'none'; frame-ancestors 'none'; form-action 'self'"
    Header set X-Content-Type-Options "nosniff"
    Header set Referrer-Policy "no-referrer"
    Header set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
    Header set X-Frame-Options "DENY"
  </FilesMatch>
  <FilesMatch "\.(?:avif|webp|jpe?g|png|svg|ico|woff2?|ttf)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(?:js|css)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "^index\.html$">
    Header set Cache-Control "no-store, max-age=0"
  </FilesMatch>
  <FilesMatch "^(?:sw\.js|manifest\.webmanifest)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json application/xml image/svg+xml
</IfModule>
