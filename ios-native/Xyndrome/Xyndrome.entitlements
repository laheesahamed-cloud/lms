<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Keychain sharing — supported on free personal teams -->
	<key>keychain-access-groups</key>
	<array>
		<string>$(AppIdentifierPrefix)com.erpm.medical.lms</string>
	</array>

	<!--
	  Push Notifications (aps-environment) and Associated Domains
	  require a PAID Apple Developer Program membership ($99/yr).
	  Re-add these before submitting to the App Store:

	  <key>aps-environment</key>
	  <string>production</string>

	  <key>com.apple.developer.associated-domains</key>
	  <array>
	    <string>applinks:xyndrome.lk</string>
	  </array>
	-->
</dict>
</plist>
