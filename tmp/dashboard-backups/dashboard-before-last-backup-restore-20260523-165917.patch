+          ].filter(Boolean).join(' ');
+          const label = item.dueCount
+            ? `${item.day} ${item.date}: ${item.dueCount} reminder${item.dueCount === 1 ? '' : 's'}`
+            : `${item.day} ${item.date}: no reminders`;
+
+          return (
+            <button
+              type="button"
+              className={`study-reminder-day ${stateClass}`}
+              key={item.key}
+              onClick={onOpenPlanner}
+              aria-label={label}
+              title={item.title || label}
+            >
+              <span>{item.day}</span>
+              <b>{item.date}</b>
+              <strong>{item.dueCount ? `${item.dueCount} due` : item.isToday ? 'Today' : 'Free'}</strong>
+              {item.dueCount ? <i aria-hidden="true">{item.dueCount}</i> : null}
+            </button>
+          );
+        })}
+      </div>
+      <div className="study-reminder-map__footer">
