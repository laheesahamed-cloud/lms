+function buildReminderMapDays(tasks, startDate = new Date()) {
+  const activeTasks = Array.isArray(tasks)
+    ? tasks.filter((task) => task?.status !== 'done')
+    : [];
+  const start = new Date(startDate.getFullYear(), startDate.getMonth(), startDate.getDate());
+  const startKey = isoFromDate(start);
+
+  return Array.from({ length: 7 }, (_, index) => {
+    const date = addDays(start, index);
+    const key = isoFromDate(date);
+    const dueTasks = activeTasks.filter((task) => {
+      const taskKey = plannerDateKey(task?.dueDate);
+      if (!taskKey) return false;
+      return index === 0 ? taskKey <= startKey : taskKey === key;
+    });
+    return {
+      key,
+      day: new Intl.DateTimeFormat(undefined, { weekday: 'short' }).format(date),
+      date: new Intl.DateTimeFormat(undefined, { day: 'numeric' }).format(date),
+      dueCount: dueTasks.length,
+      title: dueTasks[0] ? cleanPlannerTitle(dueTasks[0].title) : '',
+      isToday: index === 0,
+    };
+  });
+}
