+/* ============================================================
+   REMINDER MAP FIRST
+   Replaces the old hero card with a planner-first weekly map.
+   ============================================================ */
+.study-reminder-first-grid {
+  display: grid;
+  grid-column: 1 / -1;
+  grid-template-columns: minmax(0, 1fr);
+  gap: 14px;
+  align-items: stretch;
+}
+
+.study-reminder-map-card {
+  display: grid;
+  gap: 14px;
+  padding: 16px;
+  overflow: hidden;
+  border-color: rgba(96, 165, 250, 0.16);
+  background:
+    radial-gradient(circle at 92% 0%, rgba(96, 165, 250, 0.16), transparent 36%),
+    linear-gradient(145deg, rgba(255, 255, 255, 0.94), rgba(238, 244, 252, 0.9));
+}
+
+:root[data-theme="dark"] .study-reminder-map-card,
+.student-app-shell[data-theme="dark"] .study-reminder-map-card {
+  border-color: rgba(148, 163, 184, 0.16);
+  background:
+    radial-gradient(circle at 92% 0%, rgba(96, 165, 250, 0.1), transparent 34%),
+    linear-gradient(145deg, rgba(13, 22, 42, 0.84), rgba(6, 10, 20, 0.9));
+}
+
+.study-reminder-map__head,
+.study-reminder-map__footer {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 12px;
+  min-width: 0;
+}
+
+.study-reminder-map__head > div,
+.study-reminder-map__footer > span {
+  min-width: 0;
+}
+
+.study-reminder-map__head strong {
+  display: block;
+  margin-top: 3px;
+  color: var(--sa-ink);
+  font-size: 22px;
+  font-weight: 950;
+  line-height: 1.1;
+}
+
+.study-reminder-map__head button,
+.study-reminder-map__footer button {
+  display: inline-flex;
+  align-items: center;
+  justify-content: center;
+  gap: 7px;
+  min-height: 40px;
+  flex: 0 0 auto;
+  border: 1px solid rgba(var(--sa-primary-rgb), 0.24);
+  border-radius: 14px;
+  background: rgba(var(--sa-primary-rgb), 0.1);
+  color: var(--sa-primary);
+  cursor: pointer;
+  font-size: 12px;
+  font-weight: 900;
+  padding: 0 12px;
+}
+
+.study-reminder-map__head button svg {
+  width: 16px;
+  height: 16px;
+}
+
+.study-reminder-map__grid {
+  display: grid;
+  grid-template-columns: repeat(7, minmax(64px, 1fr));
+  gap: 8px;
+  overflow-x: auto;
+  padding-bottom: 2px;
+  scrollbar-width: none;
+}
+
+.study-reminder-map__grid::-webkit-scrollbar {
+  display: none;
+}
+
+.study-reminder-day {
+  position: relative;
+  display: grid;
+  min-width: 64px;
+  min-height: 86px;
+  gap: 5px;
+  justify-items: start;
+  border: 1px solid rgba(86, 112, 150, 0.15);
+  border-radius: 16px;
+  background: rgba(255, 255, 255, 0.54);
+  color: var(--sa-text-2);
+  cursor: pointer;
+  padding: 10px 9px;
+  text-align: left;
+}
+
+:root[data-theme="dark"] .study-reminder-day,
+.student-app-shell[data-theme="dark"] .study-reminder-day {
+  border-color: rgba(148, 163, 184, 0.14);
+  background: rgba(15, 23, 42, 0.5);
+}
+
+.study-reminder-day span,
+.study-reminder-day b,
+.study-reminder-day strong {
+  position: relative;
+  z-index: 1;
+}
+
+.study-reminder-day span {
+  color: var(--sa-primary);
+  font-size: 11px;
+  font-weight: 950;
+  line-height: 1;
+}
+
+.study-reminder-day b {
+  color: var(--sa-ink);
+  font-size: 21px;
+  font-weight: 950;
+  line-height: 1;
+}
+
+.study-reminder-day strong {
+  color: var(--sa-text-2);
+  font-size: 11px;
+  font-weight: 900;
+  line-height: 1.15;
+}
+
+.study-reminder-day i {
+  position: absolute;
+  top: 8px;
+  right: 8px;
+  display: grid;
+  width: 20px;
+  height: 20px;
+  place-items: center;
+  border-radius: 999px;
+  background: #f59e0b;
+  color: #111827;
+  font-size: 11px;
+  font-style: normal;
+  font-weight: 950;
+  line-height: 1;
+  box-shadow: 0 0 18px rgba(245, 158, 11, 0.3);
+}
+
+.study-reminder-day.is-today {
+  border-color: rgba(var(--sa-primary-rgb), 0.34);
+  background: rgba(var(--sa-primary-rgb), 0.1);
+}
+
+.study-reminder-day.is-marked {
+  border-color: rgba(245, 158, 11, 0.38);
+  background:
+    radial-gradient(circle at 88% 16%, rgba(245, 158, 11, 0.18), transparent 36%),
+    rgba(245, 158, 11, 0.08);
+}
+
+.study-reminder-day.is-marked strong {
+  color: var(--sa-warn-deep, #f59e0b);
+}
+
+.study-reminder-map__footer {
+  min-height: 40px;
+  border-top: 1px solid rgba(var(--sa-border-rgb), 0.12);
+  padding-top: 12px;
+}
+
+.study-reminder-map__footer span {
+  overflow: hidden;
+  color: var(--sa-text-2);
+  font-size: 12px;
+  font-weight: 800;
+  text-overflow: ellipsis;
+  white-space: nowrap;
+}
+
+.study-reminder-map__footer button {
+  min-height: 36px;
+}
+
+@media (max-width: 380px) {
+  .study-reminder-map-card {
+    padding: 14px;
+  }
+
+  .study-reminder-map__head,
+  .study-reminder-map__footer {
+    align-items: flex-start;
+    flex-direction: column;
+  }
+
+  .study-reminder-map__footer span {
+    white-space: normal;
+  }
+}
+
+@media (min-width: 760px) {
+  .study-reminder-first-grid {
+    grid-template-columns: minmax(0, 2fr) minmax(210px, 1fr);
+  }
+
+  .study-reminder-first-grid > .study-reminder-map-card,
+  .study-reminder-first-grid > .study-mood-card {
+    grid-column: auto !important;
+  }
+
+  .study-reminder-first-grid > .study-mood-card {
+    min-height: 238px;
+    align-content: center;
+    margin-top: 0;
+  }
+}
+
+@media (min-width: 1080px) {
+  .study-reminder-first-grid {
+    grid-template-columns: minmax(0, 2.15fr) minmax(220px, 0.85fr);
+  }
+
+  .study-reminder-first-grid > .study-reminder-map-card,
+  .study-reminder-first-grid > .study-mood-card {
+    grid-column: auto !important;
+  }
+}
