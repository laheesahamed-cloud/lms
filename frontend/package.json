{
  "name": "lms-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "lint": "eslint \"src/**/*.{js,jsx}\" \"vite.config.js\" \"tailwind.config.js\"",
    "test": "npm run build",
    "test:smoke": "npm run build",
    "build": "vite build",
    "postbuild": "node ../scripts/build/sync-root-index.mjs",
    "build:web": "VITE_LMS_BUILD_TARGET=web vite build --mode web",
    "build:pwa": "VITE_LMS_BUILD_TARGET=pwa vite build --mode pwa",
    "build:cap": "VITE_LMS_BUILD_TARGET=native CAPACITOR_BUILD=1 vite build --mode capacitor",
    "build:desktop": "VITE_LMS_BUILD_TARGET=desktop vite build --mode desktop",
    "cap:sync": "npm run build:cap && RUBYOPT=-rlogger PATH=\"$HOME/.gem/ruby/2.6.0/bin:$PATH\" CAPACITOR_COCOAPODS_PATH=\"$HOME/.gem/ruby/2.6.0/bin/pod\" cap sync",
    "cap:sync:android": "npm run build:cap && cap sync android",
    "cap:sync:ios": "npm run build:cap && RUBYOPT=-rlogger PATH=\"$HOME/.gem/ruby/2.6.0/bin:$PATH\" CAPACITOR_COCOAPODS_PATH=\"$HOME/.gem/ruby/2.6.0/bin/pod\" cap sync ios",
    "cap:open:android": "cap open android",
    "cap:open:ios": "cap open ios",
    "preview": "vite preview"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.3.4",
    "@capacitor/push-notifications": "^8.1.1",
    "@capacitor/status-bar": "^8.0.2",
    "axios": "^1.9.0",
    "html2canvas": "^1.4.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.6.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.4",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.8"
  }
}
