<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Local development builds call the LMS API over HTTP on the Mac's LAN/hotspot IP. -->
    <base-config cleartextTrafficPermitted="true" />
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">172.20.10.2</domain>
        <domain includeSubdomains="false">172.20.10.3</domain>
        <domain includeSubdomains="false">192.168.3.226</domain>
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>
</network-security-config>
