VITE_API_BASE_URL=/api
VITE_API_BASE_URLS=
VITE_API_REQUEST_TIMEOUT_MS=30000
VITE_API_TIMEOUT_RETRY_COUNT=2
VITE_API_TIMEOUT_RETRY_DELAY_MS=500
VITE_API_TIMEOUT_RETRY_WRITES=true
VITE_PWA_SW_URL=/lms/sw.js
VITE_PWA_SW_SCOPE=/lms/
VITE_LMS_BUILD_TARGET=web
VITE_ENABLE_PWA=true
VITE_PUBLIC_WEBSITE_URL=https://your-domain.com/lms
VITE_APP_ONLY_HOSTS=app.your-domain.com,app-lms.your-domain.com
VITE_APP_ONLY_HOST_PATTERN=^(app|app-lms)\.
